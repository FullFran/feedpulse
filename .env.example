NODE_ENV=development
PORT=3000
POSTGRES_HOST_PORT=55432
REDIS_HOST_PORT=56379
API_HOST_PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:55432/rss_monitor
REDIS_URL=redis://localhost:56379
DOCKER_DATABASE_URL=postgres://postgres:postgres@postgres:5432/rss_monitor
DOCKER_REDIS_URL=redis://redis:6379
WEBHOOK_NOTIFIER_URL=
WEBHOOK_NOTIFIER_TIMEOUT_MS=5000
SMOKE_API_HOST_PORT=3300
SMOKE_POSTGRES_HOST_PORT=56432
SMOKE_REDIS_HOST_PORT=57379
SMOKE_MONITORING_PORT=4010
SCHEDULER_TICK_MS=15000
SCHEDULER_BATCH_SIZE=100
WORKER_CONCURRENCY=5
FETCH_TIMEOUT_MS=10000
LOG_LEVEL=info
RATE_LIMIT_REQUESTS_PER_SECOND=2
RATE_LIMIT_MAX_BACKOFF_MS=60000
RATE_LIMIT_BASE_BACKOFF_MS=1000
# Port where the worker exposes its /metrics endpoint (aggregated by the API's /metrics)
WORKER_METRICS_PORT=3001
WORKER_METRICS_HOST_PORT=3001
