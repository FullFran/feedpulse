# Core runtime
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Database/Redis credentials (used by compose.dokploy.yml)
POSTGRES_DB=rss_monitor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# Internal container-to-container URLs (Dokploy / Docker network)
DATABASE_URL=postgres://postgres:change_me@postgres:5432/rss_monitor
REDIS_URL=redis://redis:6379

# Optional notifier
WEBHOOK_NOTIFIER_URL=
WEBHOOK_NOTIFIER_TIMEOUT_MS=5000
RESEND_API_KEY=
RESEND_FROM_EMAIL=
TELEGRAM_BOT_TOKEN=
TENANT_SECRETS_MASTER_KEY=
TELEGRAM_API_URL=https://api.telegram.org

# Scheduler / worker tuning
SCHEDULER_TICK_MS=15000
SCHEDULER_BATCH_SIZE=100
WORKER_CONCURRENCY=5
FETCH_TIMEOUT_MS=10000
OPML_UPLOAD_MAX_BYTES=10485760
RATE_LIMIT_REQUESTS_PER_SECOND=2
RATE_LIMIT_MAX_BACKOFF_MS=60000
RATE_LIMIT_BASE_BACKOFF_MS=1000
# Port where the worker exposes its /metrics endpoint (aggregated by the API's /metrics)
WORKER_METRICS_PORT=3001

# Auth
ENABLE_AUTH=false
AUTH_PROVIDER=clerk_api_key
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_API_URL=https://api.clerk.com

# --- Local/dev overrides (optional) ---
# Uncomment only when running host-mode docker compose locally.
# POSTGRES_HOST_PORT=55432
# REDIS_HOST_PORT=56379
# API_HOST_PORT=3000
# DOCKER_DATABASE_URL=postgres://postgres:postgres@postgres:5432/rss_monitor
# DOCKER_REDIS_URL=redis://redis:6379
# SMOKE_API_HOST_PORT=3300
# SMOKE_POSTGRES_HOST_PORT=56432
# SMOKE_REDIS_HOST_PORT=57379
# SMOKE_MONITORING_PORT=4010
# WORKER_METRICS_HOST_PORT=3001
